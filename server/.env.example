# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL="file:./dev.db"
# For production: DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT (MUST change in production! Use a strong random string of at least 32 characters)
JWT_SECRET=change-me-to-a-strong-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# AI - DeepSeek (optional, uncomment to enable)
# Model: deepseek-reasoner (thinking model, CoT + answer share max_tokens budget)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# AI - Xiaomi MiMo (optional, direct API access)
# MIMO_API_KEY=your-mimo-api-key
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Web Push VAPID Keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:youji@app.com

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Amap (高德地图) - Required for location services
# Apply at: https://lbs.amap.com/ (select "Web服务API" key type)
AMAP_KEY=your-amap-key

# QWeather (和风天气) - Required for weather services
# Apply at: https://dev.qweather.com/
# Authentication method 1: API KEY (simple, but will be rate-limited from 2027)
QWEATHER_API_KEY=your-qweather-api-key
# Authentication method 2: JWT (recommended, Ed25519 signing)
# Get your keys from QWeather console -> Settings -> Authentication
# QWEATHER_JWT_PRIVATE_KEY=your-base64-encoded-ed25519-private-key
# QWEATHER_JWT_CREDENTIAL_ID=your-credential-id
# QWEATHER_JWT_PROJECT_ID=your-project-id
# Your dedicated API host from QWeather console (Settings page)
# IMPORTANT: You MUST use your own API Host, public hosts (api.qweather.com, devapi.qweather.com) will return 403
# Find it at: https://console.qweather.com/setting
# Format: abc1234xyz.def.qweatherapi.com
QWEATHER_API_HOST=your-dedicated-api-host.qweatherapi.com

# Aliyun SMS (号码认证服务) - Required for SMS verification
# Apply at: https://www.aliyun.com/product/dypns
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=your-sign-name
ALIYUN_SMS_TEMPLATE_CODE=your-template-code
